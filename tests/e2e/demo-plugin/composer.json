{
    "name": "juvo/as-processor-demo",
    "description": "Demo plugin for the AS Processor library. Used as an application-test fixture.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "juvo/as-processor": "@dev",
        "juvo/as-processor-csv": "@dev",
        "juvo/as-processor-excel": "@dev",
        "juvo/as-processor-json": "@dev",
        "juvo/as-processor-api": "@dev"
    },
    "repositories": {
        "as-processor": {
            "type": "path",
            "url": "../as-processor-library-src",
            "options": {
                "symlink": false
            }
        },
        "as-processor-csv": {
            "type": "path",
            "url": "../as-processor-library-src/packages/csv",
            "options": {
                "symlink": false
            }
        },
        "as-processor-excel": {
            "type": "path",
            "url": "../as-processor-library-src/packages/excel",
            "options": {
                "symlink": false
            }
        },
        "as-processor-json": {
            "type": "path",
            "url": "../as-processor-library-src/packages/json",
            "options": {
                "symlink": false
            }
        },
        "as-processor-api": {
            "type": "path",
            "url": "../as-processor-library-src/packages/api",
            "options": {
                "symlink": false
            }
        },
        "packagist-filtered": {
            "type": "composer",
            "url": "https://repo.packagist.org",
            "exclude": ["juvo/as-processor", "juvo/as-processor-csv", "juvo/as-processor-excel", "juvo/as-processor-json", "juvo/as-processor-api"]
        },
        "packagist.org": false
    },
    "autoload": {
        "psr-4": {
            "AS_Processor_Demo\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
