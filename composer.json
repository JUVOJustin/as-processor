{
    "name": "juvo/as-processor",
    "description": "Core synchronization, chunking, and tracking runtime for AS Processor.",
    "keywords": ["wordpress", "action scheduler", "scheduler", "data"],
    "license": "GPL-3.0-or-later",
    "type": "library",
    "require": {
        "php": ">=8.1.0",
        "woocommerce/action-scheduler": "^3.7"
    },
    "support"     : {
        "issues" : "https://github.com/JUVOJustin/wp-secure-actions/issues"
    },
    "authors": [
        {
            "name": "Justin Vogt",
            "email": "mail@justin-vogt.de",
            "homepage": "https://justin-vogt.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "juvo\\AS_Processor\\": "packages/core/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "juvo\\AS_Processor\\Tests\\": "packages/core/tests/"
        }
    },
    "repositories": {
        "as-processor-csv": {
            "type": "path",
            "url": "packages/csv",
            "options": {
                "symlink": true
            }
        },
        "as-processor-excel": {
            "type": "path",
            "url": "packages/excel",
            "options": {
                "symlink": true
            }
        },
        "as-processor-json": {
            "type": "path",
            "url": "packages/json",
            "options": {
                "symlink": true
            }
        },
        "as-processor-api": {
            "type": "path",
            "url": "packages/api",
            "options": {
                "symlink": true
            }
        }
    },
    "require-dev": {
        "juvo/as-processor-csv": "^1.0@dev",
        "juvo/as-processor-excel": "^1.0@dev",
        "juvo/as-processor-json": "^1.0@dev",
        "juvo/as-processor-api": "^1.0@dev",
        "phpstan/phpstan": "^1.10.6",
        "szepeviktor/phpstan-wordpress": "^v1.1.7",
        "phpstan/extension-installer": "^1.1",
        "phpunit/phpunit": "^9.6",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "config": {
        "platform": {
            "php": "8.1.32"
        },
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "archive": {
        "exclude": [
            "/packages/api",
            "/packages/csv",
            "/packages/excel",
            "/packages/json",
            "/packages/core/tests",
            "/tests",
            "/.github",
            "/.ddev",
            "/.claude",
            "/.git*",
            "/package*.json",
            "/*.xml",
            "/*.neon",
            "/AGENTS.md"
        ]
    },
    "scripts": {
        "test:unit": "@php ./vendor/bin/phpunit -c phpunit.xml",
        "phpstan": "@php ./vendor/bin/phpstan analyse",
        "phpstan:ci": "@php ./vendor/bin/phpstan analyse --error-format=checkstyle | cs2pr",
        "phpcs": "@php ./vendor/bin/phpcs --report-full",
        "phpcs:ci": "@phpcs --report-checkstyle=./phpcs-report.xml",
        "phpcbf": "@php ./vendor/bin/phpcbf"
    }
}
